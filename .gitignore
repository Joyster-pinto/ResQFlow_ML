# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env.local

# ── Environment / Secrets ─────────────────────────────────────────────────────
.env
*.env
*.secret

# ── Trained ML models ─────────────────────────────────────────────────────────
# (large binary files — regenerated by running trainer.py)
models/*.lgb
models/*.cbm
models/*.pt
models/*.pkl
models/*.json
# Keep the models/ directory itself
!models/.gitkeep

# ── Data files ────────────────────────────────────────────────────────────────
data/*.csv
data/*.parquet
data/*.hdf5
!data/.gitkeep

# ── SUMO generated files ──────────────────────────────────────────────────────
sumo/**/*.rou.alt.xml
sumo/**/*.summary.xml
sumo/**/*.fcd.xml
sumo/**/*.tripinfo.xml
sumo/**/*.log

# ── Logs & output ─────────────────────────────────────────────────────────────
*.log
app_output.txt
*.out

# ── IDE & Editor ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Testing & Coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
*.xml

# ── Build artifacts ───────────────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Temporary / verification files ───────────────────────────────────────────
station_check.html
app_output.txt
/tmp/
